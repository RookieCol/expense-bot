TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=sk-or-v1-your-key-here
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
GOOGLE_DRIVE_FOLDER_ID=
PORT=3000

# WhatsApp via Twilio (optional — only needed if using WhatsApp channel)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
